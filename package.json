{
  "name": "barbearia-lords",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --port 5000 --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc && vite build",
    "db:push": "drizzle-kit push"
  },
